# ISOs — too big for git
isos/
*.iso

# Terraform state and cache
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/*.tfstate
terraform/*.tfstate.*
terraform/*.tfvars
!terraform/*.tfvars.example

# Ansible
ansible/*.retry
ansible/.vault_pass

# Secrets — never commit
*.key
*.pem
secrets/
.env

# macOS
.DS_Store

# Editor
.vscode/
.idea/
*.swp
